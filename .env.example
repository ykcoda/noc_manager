# SolarWinds credentials
# Tip: use an IP address (e.g. 10.0.0.10) if hostname DNS fails inside Docker
SW_HOSTNAME=solarwinds.yourdomain.net
SW_USERNAME=admin
SW_PASSWORD=your_password_here

# vCenter credentials
# Tip: use an IP address (e.g. 10.0.0.20) if hostname DNS fails inside Docker
VC_HOSTNAME=vcenter.yourdomain.net
VC_USERNAME=administrator@vsphere.local
VC_PASSWORD=your_vcenter_password_here

# OpenAI
OPENAI_API_KEY=sk-...
